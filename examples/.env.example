# ============================================================================
# .env.example
# ============================================================================
# Полный шаблон переменных окружения "Студии программирования" v2.0.
#
# Инструкция:
#   1. Скопируйте этот файл в studio/.env:
#        cp examples/.env.example studio/.env
#   2. Заполните все значения (замените <...>).
#   3. Сгенерируйте секреты командами openssl rand (см. ниже).
#   4. Установите права chmod 600 studio/.env.
#   5. Добавьте studio/.env в .gitignore.
#
# Ключевые изменения v2.0:
#   - HERMES_POSTGRES_URL — основная точка подключения к мозгу.
#   - SOA_CLIENT_ID / SOA_CLIENT_SECRET — OAuth 2.1 для Stack Overflow for
#     Agents (получить на https://stackapps.com/apps/oauth).
#   - HERMES_MCP_SERVER_TOKEN — bearer-токен для подключения IDE к Hermes
#     как к MCP-серверу (Hermes v0.6.0+).
#   - NC_AUTH_JWT_SECRET — для NocoDB (только приборная панель, не мозг).
#
# Все секреты указаны как плейсхолдеры с инструкцией по генерации.
# Без эмодзи, комментарии на русском.
# ============================================================================

# === PostgreSQL (hermes_brain база — МОЗГ системы) ===
# База, в которой лежат таблицы public.skills, public.handoff_documents,
# public.agent_sessions, public.api_keys_audit, плюс мультитенантные схемы
# studio_<tenant_id>. NocoDB подключается к этому же инстансу.
POSTGRES_DB=hermes_db
POSTGRES_USER=hermes_user
# Генерация: openssl rand -base64 24
POSTGRES_PASSWORD=<openssl rand -base64 24>
# Полная строка подключения (используется всеми агентами через MCP):
HERMES_POSTGRES_URL=postgresql://hermes_user:PASSWORD@nocodb-postgres-db:5432/hermes_brain

# === NocoDB (только UI-приборная панель, подключается к тому же PostgreSQL) ===
# NocoDB НЕ является мозгом в v2.0 — только Kanban/CRM/формы для человека.
# Генерация: openssl rand -hex 32
NC_AUTH_JWT_SECRET=<openssl rand -hex 32>

# === LLM API ===
DEEPSEEK_API_KEY=sk-deepseek-...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# === GitHub ===
# Personal Access Token с правами repo, workflow.
GITHUB_TOKEN=ghp_<PAT с правами repo, workflow>
# Генерация: openssl rand -hex 20
GITHUB_WEBHOOK_SECRET=<openssl rand -hex 20>
# Репозиторий проекта в формате owner/repo.
GITHUB_REPOSITORY=myorg/myrepo

# === Stack Overflow for Agents (OAuth 2.1) ===
# Зарегистрируйте приложение на https://stackapps.com/apps/oauth.
# Redirect URI: http://localhost:8082/oauth/callback
SOA_CLIENT_ID=<из https://stackapps.com/apps/oauth>
SOA_CLIENT_SECRET=<сгенерированный секрет>

# === Slack (опционально, для уведомлений) ===
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C...

# === Sentry (опционально, для мониторинга ошибок) ===
SENTRY_DSN=https://...@sentry.io/...
SENTRY_API_TOKEN=...

# === Hermes MCP Server (для IDE типа Cursor/Claude Desktop) ===
# Hermes v0.6.0+ может выступать как MCP-сервер. Этот bearer-токен
# используется IDE для подключения к Hermes:8082.
# Генерация: openssl rand -hex 32
HERMES_MCP_SERVER_TOKEN=<openssl rand -hex 32>

# === Loop Engine ===
LOOP_TOKEN_BUDGET_DAILY=500000
LOOP_COST_LIMIT_DAILY_USD=20.00
LOOP_MAX_RETRIES_DEFAULT=3

# === Syncthing (синхронизация между хостом и VM) ===
# Получить в UI Syncthing: Settings -> API key.
SYNCTHING_API_KEY=<из UI Syncthing>

# === Timezone ===
TZ=Europe/Moscow
